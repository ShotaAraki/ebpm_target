{com}. do "$DOFILE\saez_260328.do"
{txt}
{com}. /********************************************************************
> Saez-style bunching estimator for EBPM KPI achievement ratios
> Base spec A + robustness B and C
> 
> A: bw=0.005, window=[0.98,1.02], fit range=[0.8,1.2], deg=3
> B: bw=0.002, window=[0.98,1.02], fit range=[0.8,1.2], deg=3
> C: bw=0.005, window=[0.97,1.03], fit range=[0.8,1.2], deg=3
> ********************************************************************/
. 
. clear all
{res}{txt}
{com}. set more off
{txt}
{com}. version 17
{txt}
{com}. 
. *----------------------------
. * 1. Load tidy data
. *----------------------------
. use "kpi_tidy_for_bunching.dta", clear
{err}{p 0 4 2}
file {bf:{err}kpi_tidy_for_bunching.dta}
not found
{p_end}
{txt}{search r(601), local:r(601);}

end of do-file
{search r(601), local:r(601);}

end of do-file

{search r(601), local:r(601);}

{com}. do "C:\Users\shota\ebpm_target\dofiles\saez_260328.do"
{txt}
{com}. /********************************************************************
> Saez-style bunching estimator for EBPM KPI achievement ratios
> Base spec A + robustness B and C
> 
> A: bw=0.005, window=[0.98,1.02], fit range=[0.8,1.2], deg=3
> B: bw=0.002, window=[0.98,1.02], fit range=[0.8,1.2], deg=3
> C: bw=0.005, window=[0.97,1.03], fit range=[0.8,1.2], deg=3
> ********************************************************************/
. 
. clear all
{res}{txt}
{com}. set more off
{txt}
{com}. version 17
{txt}
{com}. 
. *----------------------------
. * 1. Load tidy data
. *----------------------------
. use "$DATA_WORK/kpi_tidy_for_bunching.dta", clear
{txt}
{com}. 
. *----------------------------
. * 2. Check required variables (defined in cr_dta.do)
. *----------------------------
. capture confirm variable r_dir
{txt}
{com}. if _rc {c -(}
.         di as error "Missing variable r_dir. Re-run cr_dta.do to generate kpi_tidy_for_bunching.dta with r_dir/ok_b."
.         exit 198
. {c )-}
{txt}
{com}. capture confirm variable ok_b
{txt}
{com}. if _rc {c -(}
.         di as error "Missing variable ok_b. Re-run cr_dta.do to generate kpi_tidy_for_bunching.dta with ok_b."
.         exit 198
. {c )-}
{txt}
{com}. count if ok_b
  {res}26,013
{txt}
{com}. di as txt "Obs in bunching sample (ok_b): " r(N)
{res}{txt}Obs in bunching sample (ok_b): 26013

{com}. 
. *----------------------------
. * 3. Saez-style excess mass program (deg=3 fixed)
. *----------------------------
. capture program drop saez_excess
{txt}
{com}. program define saez_excess, rclass
{txt}  1{com}.         syntax, SPEC(string) BW(real) WL(real) WU(real) FITL(real) FITU(real)
{txt}  2{com}.         preserve
{txt}  3{com}.         keep if ok_b
{txt}  4{com}.         keep r_dir
{txt}  5{com}. 
.         * bin centers
.         gen double bin = floor(r_dir/`bw')*`bw'
{txt}  6{com}.         gen double center = bin + `bw'/2
{txt}  7{com}.         drop bin
{txt}  8{com}. 
.         * bin counts
.         collapse (count) n=r_dir, by(center)
{txt}  9{com}. 
.         * window
.         gen byte inwin = inrange(center, `wl', `wu')
{txt} 10{com}. 
.         * fit range restriction (after collapse)
.         keep if inrange(center, `fitl', `fitu')
{txt} 11{com}. 
.         * polynomial terms (deg=3)
.         gen double c1 = center
{txt} 12{com}.         gen double c2 = center^2
{txt} 13{com}.         gen double c3 = center^3
{txt} 14{com}. 
.         reg n c1 c2 c3 if !inwin
{txt} 15{com}.         predict double n_hat, xb
{txt} 16{com}. 
.         count if inwin
{txt} 17{com}.         local bins = r(N)
{txt} 18{com}.         summ n if inwin
{txt} 19{com}.         local actual = r(sum)
{txt} 20{com}.         summ n_hat if inwin
{txt} 21{com}.         local counter = r(sum)
{txt} 22{com}.         gen double excess = n - n_hat if inwin
{txt} 23{com}.         summ excess if inwin
{txt} 24{com}.         local ex = r(sum)
{txt} 25{com}. 
.         return local spec "`spec'"
{txt} 26{com}.         return scalar bw = `bw'
{txt} 27{com}.         return scalar wl = `wl'
{txt} 28{com}.         return scalar wu = `wu'
{txt} 29{com}.         return scalar fitl = `fitl'
{txt} 30{com}.         return scalar fitu = `fitu'
{txt} 31{com}.         return scalar bins = `bins'
{txt} 32{com}.         return scalar actual = `actual'
{txt} 33{com}.         return scalar counter = `counter'
{txt} 34{com}.         return scalar ex = `ex'
{txt} 35{com}.         return scalar rel_ex = `ex'/`counter'
{txt} 36{com}.         return scalar ex_share = `ex'/`actual'
{txt} 37{com}.         restore
{txt} 38{com}. end
{txt}
{com}. 
. *----------------------------
. * 4. Run A (base), B and C (robustness)
. *----------------------------
. tempname posth
{txt}
{com}. tempfile results
{txt}
{com}. postfile `posth' str10 spec double bw wl wu fitl fitu bins actual counter ex rel_ex ex_share using `results', replace
{txt}{p 0 4 2}
(file {bf}
C:\Users\shota\AppData\Local\Temp\ST_6434_000001.tmp{rm}
not found)
{p_end}

{com}. 
. * common fit range
. local fitl = 0.8
{txt}
{com}. local fitu = 1.2
{txt}
{com}. 
. * -- A (base) ---
. saez_excess, spec("A_base") bw(0.005) wl(0.98) wu(1.02) fitl(`fitl') fitu(`fitu')
