. capture confirm variable `stub'`vstart'
{txt}
{com}. if _rc {c -(}
.     di as error "Cannot find year columns like `stub'`vstart'. Check variable names with: describe"
.     exit 198
. {c )-}
{txt}
{com}. 
. reshape long `stub', i(`rowtype' `serieskey') j(vindex)
