. *----------------------------
. * 1) Direction adjustment + clean sample for bunching
. *----------------------------
. * normalize unit symbol (optional)
. capture confirm string variable 単位
{txt}
{com}. if !_rc {c -(}
.     replace 単位 = subinstr(単位, "％", "%", .) if !missing(単位)
{txt}(8,939 real changes made)
{com}. {c )-}
{txt}
{com}. 
. * direction-adjusted target/actual
. gen double target_dir = target
{txt}(4,556 missing values generated)

{com}. gen double actual_dir = actual
{txt}(28,650 missing values generated)

{com}. replace target_dir = -target if 改善の上向き下向き=="下がると良い指標" & !missing(target)
{txt}(2,886 real changes made)

{com}. replace actual_dir = -actual if 改善の上向き下向き=="下がると良い指標" & !missing(actual)
{txt}(1,881 real changes made)

{com}. 
. * achievement ratio (direction-adjusted)
. gen double r_dir = actual_dir/target_dir if !missing(actual_dir) & !missing(target_dir) & target_dir!=0
{txt}(34,379 missing values generated)

{com}. label var r_dir "achievement ratio, direction-adjusted (1=100%)"
{txt}
{com}. 
. * clean sample
. gen byte ok = 1
{txt}
{com}. replace ok = 0 if missing(target_dir) | missing(actual_dir)
{txt}(33,206 real changes made)

{com}. replace ok = 0 if target_dir<=0
{txt}(2,583 real changes made)

{com}. replace ok = 0 if actual_dir<0
{txt}(17 real changes made)

{com}. replace r_dir = . if !ok
{txt}(1,427 real changes made, 1,427 to missing)

{com}. 
. gen byte ok_b = ok
{txt}
{com}. replace ok_b = 0 if missing(r_dir)
{txt}(0 real changes made)

{com}. replace ok_b = 0 if r_dir<=0 | r_dir>3   // trimming for bunching
{txt}(1,182 real changes made)

{com}. 
. di as txt "N (ok_b) = " _N - sum(ok_b==0)  // rough; may show missing; optional
{res}{txt}N (ok_b) = 63001

{com}. count if ok_b
  {res}26,013
{txt}
{com}. di as txt "Obs in bunching sample (ok_b): " r(N)
{res}{txt}Obs in bunching sample (ok_b): 26013

{com}. 
. *----------------------------
. * 2) Saez-style excess mass program (deg=3 fixed)
. *----------------------------
. capture program drop saez_excess
{txt}
{com}. program define saez_excess, rclass
{txt}  1{com}.     syntax, SPEC(string) BW(real) WL(real) WU(real) FITL(real) FITU(real)
{txt}  2{com}. 
.     preserve
{txt}  3{com}.     keep if ok_b
{txt}  4{com}.     keep r_dir
{txt}  5{com}. 
.     * bin centers
.     gen double bin    = floor(r_dir/`bw')*`bw'
{txt}  6{com}.     gen double center = bin + `bw'/2
{txt}  7{com}.     drop bin
{txt}  8{com}. 
.     * bin counts
.     collapse (count) n=r_dir, by(center)
{txt}  9{com}. 
.     * window
.     gen byte inwin = inrange(center, `wl', `wu')
{txt} 10{com}. 
.     * fit range restriction (after collapse)
.     keep if inrange(center, `fitl', `fitu')
{txt} 11{com}. 
.     * polynomial terms (deg=3)
.     gen double c1 = center
{txt} 12{com}.     gen double c2 = center^2
{txt} 13{com}.     gen double c3 = center^3
{txt} 14{com}. 
.     reg n c1 c2 c3 if !inwin
{txt} 15{com}.     predict double n_hat, xb
{txt} 16{com}. 
.     count if inwin
{txt} 17{com}.     local bins = r(N)
{txt} 18{com}. 
.     summ n if inwin
{txt} 19{com}.     local actual = r(sum)
{txt} 20{com}. 
.     summ n_hat if inwin
{txt} 21{com}.     local counter = r(sum)
{txt} 22{com}. 
.     gen double excess = n - n_hat if inwin
{txt} 23{com}.     summ excess if inwin
{txt} 24{com}.     local ex = r(sum)
{txt} 25{com}. 
.     return local spec "`spec'"
{txt} 26{com}.     return scalar bw = `bw'
{txt} 27{com}.     return scalar wl = `wl'
{txt} 28{com}.     return scalar wu = `wu'
{txt} 29{com}.     return scalar fitl = `fitl'
{txt} 30{com}.     return scalar fitu = `fitu'
{txt} 31{com}.     return scalar bins = `bins'
{txt} 32{com}.     return scalar actual = `actual'
{txt} 33{com}.     return scalar counter = `counter'
{txt} 34{com}.     return scalar ex = `ex'
{txt} 35{com}.     return scalar rel_ex = `ex'/`counter'
{txt} 36{com}.     return scalar ex_share = `ex'/`actual'
{txt} 37{com}. 
.     restore
{txt} 38{com}. end
{txt}
{com}. 
. *----------------------------
. * 3) Run A (base), B and C (robustness)
. *----------------------------
. tempname posth
{txt}
{com}. tempfile results
{txt}
{com}. postfile `posth' str10 spec double bw wl wu fitl fitu bins actual counter ex rel_ex ex_share using `results', replace
