{txt}
{com}. 
. /*---
>     
> - Figure A1: Distribution of direction-adjusted achievement ratio (r_dir)
> - Consistent with:
> - 
>     - cr_[[dta.do](http://dta.do)]: produces kpi_tidy_for_bunching.dta
> - 
>     - saez_[[260328.do](http://260328.do)]: defines target_dir/actual_dir, r_dir, ok_b
> - 
> - Outputs (fixed file names):
> - 
>     - figure/fig_A1_all_bw001.png     (0–3, bin=0.01)
> - 
>     - figure/fig_A1_zoom_bw0005.png   (0.8–1.2, bin=0.005)
> - 
>     - figure/fig_A1_zoom_bw0002.png   (0.8–1.2, bin=0.002)
> - 
>     
>     ---*/
.     
. 
. cap mkdir "figure"
{txt}
{com}. 
. * 1) Load tidy data
. 
. use "$DATA_WORK\kpi_tidy_for_bunching.dta", clear
{txt}
{com}. 
. * 2) Preprocess (same logic as saez_[[260328.do](http://260328.do)])
. 
. capture confirm string variable 単位
{txt}
{com}. 
. if !_rc {c -(}
. 
. replace 単位 = subinstr(単位, "％", "%", .) if !missing(単位)
{txt}(8,939 real changes made)
{com}. 
. {c )-}
{txt}
{com}. 
. gen double target_dir = target
{txt}(4,556 missing values generated)

{com}. 
. gen double actual_dir = actual
{txt}(28,650 missing values generated)

{com}. 
. replace target_dir = -target if 改善の上向き下向き=="下がると良い指標" & !missing(target)
{txt}(2,886 real changes made)

{com}. 
. replace actual_dir = -actual if 改善の上向き下向き=="下がると良い指標" & !missing(actual)
{txt}(1,881 real changes made)

{com}. 
. gen double r_dir = actual_dir/target_dir if !missing(actual_dir) & !missing(target_dir) & target_dir!=0
{txt}(34,379 missing values generated)

{com}. 
. label var r_dir "achievement ratio, direction-adjusted (1=100%)"
{txt}
{com}. 
. gen byte ok = 1
{txt}
{com}. 
. replace ok = 0 if missing(target_dir) | missing(actual_dir)
{txt}(33,206 real changes made)

{com}. 
. replace ok = 0 if target_dir<=0
{txt}(2,583 real changes made)

{com}. 
. replace ok = 0 if actual_dir<0
{txt}(17 real changes made)

{com}. 
. replace r_dir = . if !ok
{txt}(1,427 real changes made, 1,427 to missing)

{com}. 
. gen byte ok_b = ok
{txt}
{com}. 
. replace ok_b = 0 if missing(r_dir)
{txt}(0 real changes made)

{com}. 
. replace ok_b = 0 if r_dir<=0 | r_dir>3
{txt}(1,182 real changes made)

{com}. 
. count if ok_b
  {res}26,013
{txt}
{com}. 
. local N_okb = r(N)
{txt}
{com}. 
. di as txt "Obs in bunching sample (ok_b): `N_okb'"
{res}{txt}Obs in bunching sample (ok_b): 26013

{com}. 
. * 3) Plot settings
. 
. set scheme s2color
{txt}
{com}. 
. * 4) Figure A1(a): full range 0–3, bin=0.01
. 
. histogram r_dir if ok_b, ///
> 
{txt}(bin={res}44{txt}, start={res}.00001697{txt}, width={res}.06818143{txt})
{res}{txt}
{com}. width(0.01) start(0) ///
